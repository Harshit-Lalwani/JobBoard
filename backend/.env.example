NODE_ENV=development
PORT=4000

MONGO_URI=mongodb://127.0.0.1:27017/jobboard

JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

CORS_ORIGIN=http://localhost:5173

# Resume upload storage — leave all unset for local disk (dev/tests default, no setup needed).
# GCS is tried first if GCS_BUCKET is set, then Vercel Blob if BLOB_READ_WRITE_TOKEN is set.
GCS_BUCKET=
# Local dev / GCP-hosted runtimes: point this at a service-account key file instead of using
# GOOGLE_APPLICATION_CREDENTIALS_JSON below.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# Serverless hosts (Vercel) can't reference a local file path — paste the key file's JSON
# contents here instead (single line). Takes precedence over GOOGLE_APPLICATION_CREDENTIALS above.
GOOGLE_APPLICATION_CREDENTIALS_JSON=
BLOB_READ_WRITE_TOKEN=
